graph TB
    subgraph "llm-pipeline System"
        subgraph "Pipeline Orchestrator Container"
            PipelineConfig["<b>PipelineConfig</b><br/>Declarative pipeline config<br/>[Python/Pydantic]"]
            StrategySystem["<b>Strategy System</b><br/>Strategy selection & routing<br/>[Python/Pydantic]"]
            StepExecution["<b>Step Execution Engine</b><br/>LLMStep execution<br/>[Python/ABC]"]
            ExtractionEngine["<b>Extraction Engine</b><br/>PipelineExtraction handlers<br/>[Python]"]
            TransformationEngine["<b>Transformation Engine</b><br/>PipelineTransformation handlers<br/>[Python]"]
        end

        subgraph "LLM Integration Container"
            LLMProvider["<b>LLMProvider</b><br/>Abstract LLM interface<br/>[Python/ABC]"]
            GeminiProvider["<b>GeminiProvider</b><br/>Google Gemini implementation<br/>[Python/google-generativeai]"]
            SchemaFormatter["<b>Schema Formatter</b><br/>LLM schema preprocessing<br/>[Python]"]
            RateLimiter["<b>Rate Limiter</b><br/>API throttling<br/>[Python]"]
        end

        subgraph "Prompt Management Container"
            PromptService["<b>PromptService</b><br/>Prompt CRUD & retrieval<br/>[Python]"]
            PromptLoader["<b>Prompt Loader</b><br/>YAML-to-DB sync<br/>[Python/PyYAML]"]
            VariableResolver["<b>Variable Resolver</b><br/>Template variable extraction<br/>[Python]"]
            PromptCache["<b>Prompt Cache</b><br/>In-memory prompt cache<br/>[Python]"]
        end

        subgraph "State Tracking Container"
            PipelineRunInstance["<b>PipelineRunInstance</b><br/>Run execution traceability<br/>[Python/SQLModel]"]
            PipelineStepState["<b>PipelineStepState</b><br/>Step execution state<br/>[Python/SQLModel]"]
            CacheKeyGen["<b>Cache Key Generator</b><br/>input_hash + prompt_version<br/>[Python]"]
        end

        subgraph "Database Access Container"
            PipelineRegistry["<b>PipelineRegistry</b><br/>DB-backed registry<br/>[SQLAlchemy/SQLModel]"]
            ReadOnlySession["<b>ReadOnlySession</b><br/>Safe DB session wrapper<br/>[Python/SQLAlchemy]"]
            DBAccess["<b>Database Access</b><br/>SQLAlchemy ORM<br/>[SQLAlchemy 2.0]"]
        end
    end

    subgraph "External Systems"
        User["<b>User/Application</b><br/>Pipeline consumer"]
        LLMService["<b>LLM Service</b><br/>Google Gemini API"]
        Database[(fa:fa-database Database<br/>SQLite/PostgreSQL)]
        PromptFiles["<b>Prompt Files</b><br/>YAML configuration"]
    end

    %% Pipeline Orchestrator -> LLM Integration
    StepExecution -->|Execute LLM call| LLMProvider
    StepExecution -->|Execute LLM call| GeminiProvider
    StrategySystem -->|Route to strategy| ExtractionEngine
    StrategySystem -->|Route to strategy| TransformationEngine
    PipelineConfig -->|Configure| StrategySystem
    PipelineConfig -->|Configure| StepExecution

    %% LLM Integration flows
    GeminiProvider -->|Format schema| SchemaFormatter
    GeminiProvider -->|Throttle requests| RateLimiter
    RateLimiter -->|Call API| LLMService

    %% Prompt Management flows
    ExtractionEngine -->|Query prompts| PromptService
    TransformationEngine -->|Query prompts| PromptService
    PromptService -->|Load from disk| PromptLoader
    PromptLoader -->|Read YAML| PromptFiles
    PromptService -->|Cache prompts| PromptCache
    PromptLoader -->|Extract vars| VariableResolver

    %% State Tracking flows
    StepExecution -->|Track execution| PipelineStepState
    StepExecution -->|Generate cache key| CacheKeyGen
    PipelineStepState -->|Link to run| PipelineRunInstance
    CacheKeyGen -->|Store state| PipelineStepState

    %% Database Access flows
    PipelineConfig -->|Register models| PipelineRegistry
    PipelineRegistry -->|Validate FK order| DBAccess
    ExtractionEngine -->|Write extracted data| ReadOnlySession
    PipelineStepState -->|Persist state| ReadOnlySession
    PromptService -->|Query prompts| DBAccess
    ReadOnlySession -->|Read/Write| DBAccess
    DBAccess -->|Connect| Database

    %% External interactions
    User -->|Execute pipeline| PipelineConfig
    User -->|Configure provider| GeminiProvider
    Database -->|Store state & prompts| PromptService
    PromptFiles -->|Provide prompts| PromptLoader

    classDef container fill:#85BBF0,stroke:#003DA5,stroke-width:2px,color:#000
    classDef external fill:#D2ECFF,stroke:#003DA5,stroke-width:1px,color:#000
    classDef database fill:#F5F5F5,stroke:#666,stroke-width:2px,color:#000

    class PipelineConfig,StrategySystem,StepExecution,ExtractionEngine,TransformationEngine,LLMProvider,GeminiProvider,SchemaFormatter,RateLimiter,PromptService,PromptLoader,VariableResolver,PromptCache,PipelineRunInstance,PipelineStepState,CacheKeyGen,PipelineRegistry,ReadOnlySession,DBAccess container
    class User,LLMService,PromptFiles external
    class Database database
